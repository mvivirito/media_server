# Secrets never belong in this repo — they live in Portainer stack env vars
# (see .env.example and SECURITY.md). These patterns guard against accidental
# local secret files being committed. The tracked .env holds only CONFIG_BASE.
*.env.local
.env.*.local
secrets*
*.secret
*.key
*wireguard*.conf
wg*.conf

# python bytecode from local edits of the collector
__pycache__/
*.pyc
