# Template for the stack environment variables.
#
# On the NAS these are set as Portainer STACK ENVIRONMENT VARIABLES (per stack),
# NOT committed files — secrets must never land in this repo. Copy this to
# `.env` only for local `docker compose config` validation.

# --- media.yml ---
CONFIG_BASE=/volume1/configs   # persistent config root on the RAID volume (non-secret)
TOKEN=                         # Cloudflare Tunnel token for cloudflared  [SECRET]

# --- booklore.yml ---
MYSQL_ROOT_PASS=               # MariaDB root password                    [SECRET]
MYSQL_PASS=                    # BookLore DB user password                [SECRET]

# --- homepage.yml (optional widget API keys; dashboard renders without them) ---
# Set in Portainer; referenced in homepage/config/services.yaml as {{HOMEPAGE_VAR_*}}.
# HOMEPAGE_VAR_SONARR_KEY=     # Sonarr  Settings → General → API Key      [SECRET]
# HOMEPAGE_VAR_RADARR_KEY=     # Radarr  API key                          [SECRET]
# HOMEPAGE_VAR_SABNZBD_KEY=    # SABnzbd Config → General → API Key        [SECRET]
# HOMEPAGE_VAR_BAZARR_KEY=     # Bazarr  API key                          [SECRET]
# HOMEPAGE_VAR_EMBY_KEY=       # Emby    API key                          [SECRET]

# --- downloader-vpn.yml.example (optional, see SECURITY.md) ---
# WG_PRIVATE_KEY=              # WireGuard private key from the VPN provider [SECRET]
# WG_ADDRESSES=                # WireGuard interface address, e.g. 10.2.0.2/32
