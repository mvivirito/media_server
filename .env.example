# Stack environment variables. On the NAS these are set as Portainer stack
# environment variables (per stack), never committed. Copy to `.env` only for
# local `docker compose config` validation. Placeholders below are examples.

# --- media.yml ---
CONFIG_BASE=/volume1/configs   # persistent config root
TOKEN=                         # tunnel token for the optional cloudflared service  [SECRET]

# --- homepage.yml ---
HOMEPAGE_ALLOWED_HOSTS=        # host(s) the dashboard is reached by, e.g. dash.example.com,192.168.1.10:3000
HOMEPAGE_VAR_DOMAIN=           # base domain for dashboard links, e.g. example.com
HOMEPAGE_VAR_NAS=              # host/IP for services without a vhost, e.g. 192.168.1.10
# HOMEPAGE_VAR_SONARR_KEY=     # Sonarr  API key   [SECRET]
# HOMEPAGE_VAR_RADARR_KEY=     # Radarr  API key   [SECRET]
# HOMEPAGE_VAR_SABNZBD_KEY=    # SABnzbd API key   [SECRET]
# HOMEPAGE_VAR_BAZARR_KEY=     # Bazarr  API key   [SECRET]
# HOMEPAGE_VAR_EMBY_KEY=       # Emby    API key   [SECRET]

# --- booklore.yml ---
MYSQL_ROOT_PASS=               # MariaDB root password      [SECRET]
MYSQL_PASS=                    # BookLore DB user password  [SECRET]

# --- downloader-vpn.yml.example (optional) ---
# WG_PRIVATE_KEY=              # WireGuard private key from the VPN provider  [SECRET]
# WG_ADDRESSES=                # WireGuard interface address
